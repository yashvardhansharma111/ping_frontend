{
  "expo": {
    "name": "Ping",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ping",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pingnow.app"
    },
    "android": {
      "package": "com.pingnow.app",
      "adaptiveIcon": {
        "backgroundColor": "#080815",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Ping uses your location to show nearby activities and let friends find you.",
          "locationAlwaysAndWhenInUsePermission": "Ping uses your location to show nearby activities and let friends find you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#080815",
          "dark": {
            "backgroundColor": "#080815"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://app.pingnow.in",
      "eas": {
        "projectId": "a42800fa-7544-4d59-a1a3-cd004c63424d"
      },
      "router": {}
    },
    "owner": "bensharma"
  }
}
